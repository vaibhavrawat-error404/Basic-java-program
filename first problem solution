// Sum of Numbers (Loop + Control Statement)

import java.util.Scanner;

public class Main{
  public static void main(String[] args){

System.out.println("ENTER THE LAST NUMBER TILL YOU WANT SUM");
Scanner scanner=new Scanner(System.in);
int n=scanner.nextInt();

int sum=0;

for(int i=0;i<=n;i++){
 sum+=i;
}

System.out.println("SUM OF ALL THE NUMBERS FROM 0 TO "+n+" IS "+sum);
}
}
